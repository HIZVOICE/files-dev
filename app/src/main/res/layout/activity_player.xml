<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/videoLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <ImageView
        android:id="@+id/audioArt"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_audio"
        android:visibility="gone"
        android:contentDescription="Audio" />

    <!-- Chrome (fades together) -->
    <FrameLayout
        android:id="@+id/controls"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_gravity="top"
            android:background="@drawable/scrim_top" />

        <View
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_gravity="bottom"
            android:background="@drawable/scrim_bottom" />

        <!-- Floating frosted top bar -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginHorizontal="8dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_glass_bar"
            android:paddingHorizontal="4dp"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="@color/white"
                android:background="@drawable/bg_glass_circle"
                android:contentDescription="Back" />

            <TextView
                android:id="@+id/playerTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:maxLines="1"
                android:ellipsize="middle"
                android:text=""
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnMute"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:padding="10dp"
                android:src="@drawable/ic_volume"
                app:tint="@color/white"
                android:background="@drawable/bg_glass_circle"
                android:contentDescription="Mute" />

            <ImageView
                android:id="@+id/btnShare"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:padding="10dp"
                android:src="@drawable/ic_share"
                app:tint="@color/white"
                android:background="@drawable/bg_glass_circle"
                android:contentDescription="Share" />

            <TextView
                android:id="@+id/btnSpeed"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:minWidth="46dp"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="1x"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_glass_bar"
                android:contentDescription="Playback speed" />

            <ImageView
                android:id="@+id/btnAspect"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:padding="10dp"
                android:src="@drawable/ic_aspect"
                app:tint="@color/white"
                android:background="@drawable/bg_glass_circle"
                android:contentDescription="Aspect ratio" />
        </LinearLayout>

        <!-- Floating frosted bottom controls card -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_bar"
            android:paddingHorizontal="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="8dp">

            <!-- Seek row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/timeCurrent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="10dp"
                    android:progressDrawable="@drawable/sb_progress"
                    android:thumb="@drawable/sb_thumb"
                    android:splitTrack="false"
                    android:maxHeight="6dp"
                    android:minHeight="6dp" />

                <TextView
                    android:id="@+id/timeTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <ImageView
                    android:id="@+id/btnRotate"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:padding="9dp"
                    android:src="@drawable/ic_rotate"
                    app:tint="@color/white"
                    android:background="@drawable/bg_glass_circle"
                    android:contentDescription="Rotate" />
            </LinearLayout>

            <!-- Transport row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="2dp">

                <ImageView
                    android:id="@+id/btnRewind"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_rewind"
                    app:tint="@color/white"
                    android:background="@drawable/bg_glass_circle"
                    android:contentDescription="Rewind 10s" />

                <ImageView
                    android:id="@+id/btnPrev"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="10dp"
                    android:padding="13dp"
                    android:src="@drawable/ic_prev"
                    app:tint="@color/white"
                    android:background="@drawable/bg_glass_circle"
                    android:contentDescription="Previous" />

                <FrameLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@drawable/bg_play_circle">

                    <ImageView
                        android:id="@+id/btnPlayPause"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp"
                        android:src="@drawable/ic_play"
                        app:tint="@color/white"
                        android:contentDescription="Play/Pause" />
                </FrameLayout>

                <ImageView
                    android:id="@+id/btnNext"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="10dp"
                    android:padding="13dp"
                    android:src="@drawable/ic_next"
                    app:tint="@color/white"
                    android:background="@drawable/bg_glass_circle"
                    android:contentDescription="Next" />

                <ImageView
                    android:id="@+id/btnForward"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_forward"
                    app:tint="@color/white"
                    android:background="@drawable/bg_glass_circle"
                    android:contentDescription="Forward 10s" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/gesturePanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_gesture"
        android:paddingHorizontal="22dp"
        android:paddingVertical="16dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/gestureIcon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_brightness"
            app:tint="@color/white" />

        <ProgressBar
            android:id="@+id/gestureBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="130dp"
            android:layout_height="6dp"
            android:layout_marginTop="12dp"
            android:max="100"
            android:progress="50"
            android:progressDrawable="@drawable/level_progress" />

        <TextView
            android:id="@+id/gesturePercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text=""
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
