<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp" android:height="108dp"
    android:viewportWidth="108" android:viewportHeight="108">

    <!-- Folder tab (lighter lime, peeks above the body top-left) -->
    <path
        android:pathData="M21,30 h26 a5,5 0 0 1 5,5 v13 h-36 v-13 a5,5 0 0 1 5,-5 z"
        android:fillColor="#B4CF57" />

    <!-- Folder body with a lime -> olive vertical gradient -->
    <path android:pathData="M21,40 h66 a7,7 0 0 1 7,7 v32 a7,7 0 0 1 -7,7 h-66 a7,7 0 0 1 -7,-7 v-32 a7,7 0 0 1 7,-7 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="54" android:startY="40" android:endX="54" android:endY="86">
                <item android:offset="0" android:color="#FFBBD653" />
                <item android:offset="1" android:color="#FF7E9A2E" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Android robot, embossed lighter green -->
    <!-- antennae -->
    <path android:strokeColor="#D3E77E" android:strokeWidth="1.8" android:strokeLineCap="round"
        android:pathData="M48,45 L44,37" />
    <path android:strokeColor="#D3E77E" android:strokeWidth="1.8" android:strokeLineCap="round"
        android:pathData="M60,45 L64,37" />
    <!-- head (upper half-disc) -->
    <path android:fillColor="#D3E77E" android:pathData="M43,54 a11,11 0 0 1 22,0 z" />
    <!-- body -->
    <path android:fillColor="#D3E77E"
        android:pathData="M44,55 h20 v13 a2,2 0 0 1 -2,2 h-16 a2,2 0 0 1 -2,-2 v-13 z" />
    <!-- left arm -->
    <path android:fillColor="#D3E77E"
        android:pathData="M40,56 a2,2 0 0 1 2,2 v9 a2,2 0 0 1 -4,0 v-9 a2,2 0 0 1 2,-2 z" />
    <!-- right arm -->
    <path android:fillColor="#D3E77E"
        android:pathData="M68,56 a2,2 0 0 1 2,2 v9 a2,2 0 0 1 -4,0 v-9 a2,2 0 0 1 2,-2 z" />
    <!-- left leg -->
    <path android:fillColor="#D3E77E"
        android:pathData="M49,69 a2,2 0 0 1 2,2 v6 a2,2 0 0 1 -4,0 v-6 a2,2 0 0 1 2,-2 z" />
    <!-- right leg -->
    <path android:fillColor="#D3E77E"
        android:pathData="M59,69 a2,2 0 0 1 2,2 v6 a2,2 0 0 1 -4,0 v-6 a2,2 0 0 1 2,-2 z" />
    <!-- eyes -->
    <path android:fillColor="#FFFFFF" android:pathData="M50,49 m-1.3,0 a1.3,1.3 0 1 0 2.6,0 a1.3,1.3 0 1 0 -2.6,0 z" />
    <path android:fillColor="#FFFFFF" android:pathData="M58,49 m-1.3,0 a1.3,1.3 0 1 0 2.6,0 a1.3,1.3 0 1 0 -2.6,0 z" />
</vector>
