<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp" android:height="108dp"
    android:viewportWidth="108" android:viewportHeight="108">

    <!-- Folder tab (lighter lime, subtle gradient) -->
    <path android:pathData="M21,30 h26 a5,5 0 0 1 5,5 v13 h-36 v-13 a5,5 0 0 1 5,-5 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="21" android:startY="30" android:endX="21" android:endY="48">
                <item android:offset="0" android:color="#FFCBDE72" />
                <item android:offset="1" android:color="#FFA7C24A" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Folder body — layered lime -> green -> olive gradient for depth -->
    <path android:pathData="M21,40 h66 a7,7 0 0 1 7,7 v32 a7,7 0 0 1 -7,7 h-66 a7,7 0 0 1 -7,-7 v-32 a7,7 0 0 1 7,-7 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="54" android:startY="40" android:endX="54" android:endY="86">
                <item android:offset="0" android:color="#FFCAE268" />
                <item android:offset="0.5" android:color="#FFA6C544" />
                <item android:offset="1" android:color="#FF6E8A28" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glossy highlight sweep across the upper folder face -->
    <path android:pathData="M14,47 a7,7 0 0 1 7,-7 h66 a7,7 0 0 1 7,7 v9 c-13,7 -67,7 -80,0 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="54" android:startY="40" android:endX="54" android:endY="62">
                <item android:offset="0" android:color="#70FFFFFF" />
                <item android:offset="1" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Soft shadow under the embossed robot (offset down slightly) -->
    <group android:translateX="0" android:translateY="1">
        <path android:fillColor="#38000000"
            android:pathData="M43,54 a11,11 0 0 1 22,0 z M44,55 h20 v13 a2,2 0 0 1 -2,2 h-16 a2,2 0 0 1 -2,-2 v-13 z M40,56 a2,2 0 0 1 2,2 v9 a2,2 0 0 1 -4,0 v-9 a2,2 0 0 1 2,-2 z M68,56 a2,2 0 0 1 2,2 v9 a2,2 0 0 1 -4,0 v-9 a2,2 0 0 1 2,-2 z M49,69 a2,2 0 0 1 2,2 v6 a2,2 0 0 1 -4,0 v-6 a2,2 0 0 1 2,-2 z M59,69 a2,2 0 0 1 2,2 v6 a2,2 0 0 1 -4,0 v-6 a2,2 0 0 1 2,-2 z" />
    </group>

    <!-- Robot mass with a top-to-bottom gradient (embossed volume) -->
    <path android:pathData="M43,54 a11,11 0 0 1 22,0 z M44,55 h20 v13 a2,2 0 0 1 -2,2 h-16 a2,2 0 0 1 -2,-2 v-13 z M40,56 a2,2 0 0 1 2,2 v9 a2,2 0 0 1 -4,0 v-9 a2,2 0 0 1 2,-2 z M68,56 a2,2 0 0 1 2,2 v9 a2,2 0 0 1 -4,0 v-9 a2,2 0 0 1 2,-2 z M49,69 a2,2 0 0 1 2,2 v6 a2,2 0 0 1 -4,0 v-6 a2,2 0 0 1 2,-2 z M59,69 a2,2 0 0 1 2,2 v6 a2,2 0 0 1 -4,0 v-6 a2,2 0 0 1 2,-2 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="54" android:startY="43" android:endX="54" android:endY="79">
                <item android:offset="0" android:color="#FFE7F2A2" />
                <item android:offset="1" android:color="#FFA6C24C" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Specular highlight along the top of the head -->
    <path android:strokeColor="#66FFFFFF" android:strokeWidth="1.1" android:strokeLineCap="round"
        android:pathData="M46,52 a8.4,8.4 0 0 1 16,0" />

    <!-- Antennae -->
    <path android:strokeColor="#FFC9E27A" android:strokeWidth="1.8" android:strokeLineCap="round"
        android:pathData="M48,45 L44,37" />
    <path android:strokeColor="#FFC9E27A" android:strokeWidth="1.8" android:strokeLineCap="round"
        android:pathData="M60,45 L64,37" />

    <!-- Eyes -->
    <path android:fillColor="#FFFFFFFF" android:pathData="M50,49 m-1.3,0 a1.3,1.3 0 1 0 2.6,0 a1.3,1.3 0 1 0 -2.6,0 z" />
    <path android:fillColor="#FFFFFFFF" android:pathData="M58,49 m-1.3,0 a1.3,1.3 0 1 0 2.6,0 a1.3,1.3 0 1 0 -2.6,0 z" />
